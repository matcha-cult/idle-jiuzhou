{
  "dialogues": [
    {
      "id": "dlg-main-5-001",
      "name": "第五章-001 荒原初探",
      "nodes": [
        {
          "id": "start",
          "type": "narration",
          "text": "神识荒原的气息与别处截然不同。\n虚空裂隙在远处若隐若现，神魂波动如潮水般起伏。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "荒原守望者",
          "text": "你来得正好。虚空裂隙又在扩张，神魂波动越来越不稳。\n这地方对结胎期修士来说极其危险，但也只有在这里，才能真正觉醒神识。",
          "next": "npc-2"
        },
        {
          "id": "npc-2",
          "type": "npc",
          "speaker": "荒原守望者",
          "text": "你若要深入荒原，先确认自己的神识不会被吞噬。\n先去虚空裂隙附近探查一番，回来告诉我你的感受。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：深入神识荒原，在虚空裂隙附近击败虚空残影与神魂游丝。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-5-002",
      "name": "第五章-002 虚空试炼",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "荒原守望者",
          "text": "从虚空裂隙回来了？很好，你的神魂尚未被侵蚀，说明已经初步适应了这里的灵压。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "荒原守望者",
          "text": "虚空残影与神魂游丝不过是荒原最弱的存在。真正的试炼在更深处——虚灵神殿。",
          "next": "npc-2"
        },
        {
          "id": "npc-2",
          "type": "npc",
          "speaker": "荒原守望者",
          "text": "去找虚灵引路人，他会带你进入神殿。记住，神殿不认修为，只认神魂。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：前往虚灵神殿，与虚灵引路人交谈并通关普通难度。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-5-003",
      "name": "第五章-003 神殿证道",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "虚灵引路人",
          "text": "能通过虚灵神殿的普通试炼，说明你的神识已初步觉醒。但这只是开始。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "虚灵引路人",
          "text": "养神之前，你还需要凝聚足够的神魂之力。荒原深处产出的神魂凝晶是最佳选择。",
          "next": "npc-2"
        },
        {
          "id": "npc-2",
          "type": "npc",
          "speaker": "虚灵引路人",
          "text": "收集足够的神魂凝晶，回到荒原入口找守望者。他会帮你完成最后的准备。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：收集神魂凝晶10个，向荒原守望者复命。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-5-004",
      "name": "第五章-004 神魂凝聚",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "荒原守望者",
          "text": "神魂凝晶收集齐了？让我看看……品质不错，足够支撑你完成从结胎到养神的跨越。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "荒原守望者",
          "text": "第五章的试炼到此结束。你已具备养神的资质，随时可以开始突破。\n神识荒原永远向你敞开，但更深处的危险，需要更强的神魂才能应对。",
          "next": "npc-2"
        },
        {
          "id": "npc-2",
          "type": "npc",
          "speaker": "荒原守望者",
          "text": "拿着这些养神丹和神魂凝晶，它们会在你突破时提供保护。去吧，修士。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "第五章完成：神识觉醒。已满足养神突破主线前置。"
        }
      ],
      "enabled": true
    }
  ]
}
