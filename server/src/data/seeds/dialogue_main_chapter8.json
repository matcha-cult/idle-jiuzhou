{
  "dialogues": [
    {
      "id": "dlg-main-8-001",
      "name": "第八章-001 天阙初临",
      "nodes": [
        {
          "id": "start",
          "type": "narration",
          "text": "界桥尽头不再是碎裂镜潮，而是一整片高悬天阙。\n每一道律纹都在天穹中缓慢转动，像在提前记录你将要犯下的失衡。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "引痕使",
          "text": "镜墟还会照出你的破绽，天阙则会直接替大道追账。\n你在这里每一次贪进，都会被记成一笔迟早要还的法则债。",
          "next": "npc-2"
        },
        {
          "id": "npc-2",
          "type": "npc",
          "speaker": "引痕使",
          "text": "先稳住心神，再听我说清万法天阙的规矩。\n能在这里站稳，才配谈后面的证道问律。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：抵达万法天阙，并与引痕使交谈。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-8-002",
      "name": "第八章-002 外庭清律",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "引痕使",
          "text": "先别急着进道宫，外庭的巡狩与游魂就是第一轮筛选。\n它们不强，但足够把心浮气躁的人当场拖进律纹反噬里。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "引痕使",
          "text": "去把天阙巡狩和律纹游魂清干净。\n学会看清第一拍反噬，你才有资格碰后面的道宫门槛。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：击败天阙巡狩6只、律纹游魂6只。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-8-003",
      "name": "第八章-003 灵砂归纹",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "铸纹师",
          "text": "外庭的灵砂不能只靠战意硬取，得在律纹回落的瞬间顺势收束。\n拿回来的不是材料，是你能否顺着法则而行的证明。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "铸纹师",
          "text": "去收齐十二份天阙灵砂，再回来让我替你把法印底纹压稳。\n底纹不稳，进了道宫也只会被第一轮高压律音震散。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：收集天阙灵砂12个，并向铸纹师复命。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-8-004",
      "name": "第八章-004 道宫初问",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "执律天官",
          "text": "万法道宫的第一轮问律不会立刻击垮你，它只会不断提醒你哪一步还不够稳。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "执律天官",
          "text": "先进去走一趟，扛过第一轮法则并临。\n能活着出来，才说明你具备继续压实证道法印的底子。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：通关万法道宫 1 次。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-8-005",
      "name": "第八章-005 镇章压律",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "引痕使",
          "text": "前一轮问律只是开门砖，真正会逼你出错的是镇章台上的精英执法者。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "引痕使",
          "text": "去把镇章使和问天执炬都压下去。\n只有能扛住它们的追偿节奏，你后面才不会在高压问律里当场崩盘。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：击败镇章使2只、问天执炬2只。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-8-006",
      "name": "第八章-006 道宫再问",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "执律天官",
          "text": "法印底纹已经立住，接下来不是补材料，而是把它放进更重的法则里反复压实。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "执律天官",
          "text": "去完成两轮问律，让万法道宫亲自检验你的节奏。\n扛不过去，说明你离证道还差最后一层骨气。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：通关万法道宫 2 次。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-8-007",
      "name": "第八章-007 法印既成",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "执律天官",
          "text": "现在差的不是更多试炼，而是把足量证道法印真正收束回来。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "执律天官",
          "text": "收齐四枚证道法印后再来见我。\n法印齐了，你的神识与法则才算真正具备同频证真的资格。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：收集证道法印4个，并向执律天官复命。"
        }
      ],
      "enabled": true
    },
    {
      "id": "dlg-main-8-008",
      "name": "第八章-008 开阙留名",
      "nodes": [
        {
          "id": "start",
          "type": "npc",
          "speaker": "执律天官",
          "text": "法印底纹已经稳住，剩下的是把天阙灵砂收束到足以开阙留名的份量。",
          "next": "npc-1"
        },
        {
          "id": "npc-1",
          "type": "npc",
          "speaker": "执律天官",
          "text": "去把三十份天阙灵砂收齐，再回来向我复命。\n名字刻上天阙之后，你才算真正拿到了叩开证道之门的资格。",
          "next": "end"
        },
        {
          "id": "end",
          "type": "system",
          "text": "目标更新：收集天阙灵砂30个，并向执律天官复命。"
        }
      ],
      "enabled": true
    }
  ]
}
